{
  "productName": "Dream Light Console",
  "version": "0.1.0",
  "identifier": "dev.dreamlightconsole.dmx",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Dream Light Console",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app", "msi", "appimage"],
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "shell": {
      "sidecar": true
    }
  }
}
